{
  "expo": {
    "name": "Safe My Plants",
    "slug": "safe-my-plants",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.github.s540d.safemyplants"
    },
    "android": {
      "package": "io.github.s540d.safemyplants",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#2D6A4F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "experiments": {
      "baseUrl": "/safe-my-plants"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "Safe My Plants möchte auf deine Fotos zugreifen, um Pflanzenbilder hinzuzufügen.",
          "cameraPermission": "Safe My Plants möchte deine Kamera nutzen, um Pflanzenfotos aufzunehmen."
        }
      ],
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2D6A4F",
          "dark": {
            "backgroundColor": "#0D1F17"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2D6A4F"
        }
      ]
    ],
    "scheme": "safemyplants"
  }
}
